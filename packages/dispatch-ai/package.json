{
  "name": "dispatch-ai",
  "version": "0.0.1",
  "description": "Global installer package for dispatch.ai CLI and detector.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dispatch-ai-labs/dispatch-ai.git"
  },
  "type": "module",
  "bin": {
    "dispatch": "./dist/node/dispatch.js",
    "dispatch-detector": "./dist/node/dispatch-detector.js"
  },
  "files": ["dist/node", "README.md"],
  "scripts": {
    "typecheck": "echo 'compat package only'",
    "build": "bun build src/dispatch.ts src/dispatch-detector.ts --target=node --format=esm --outdir dist/node --external @dispatch-ai/cli --external @dispatch-ai/detector",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@dispatch-ai/cli": "workspace:*",
    "@dispatch-ai/detector": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
