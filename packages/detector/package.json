{
  "name": "@dispatch-ai/detector",
  "version": "0.0.1",
  "description": "Placeholder + fake-import detector for AI-generated Python diffs.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dispatch-ai-labs/dispatch-ai.git"
  },
  "type": "module",
  "main": "./dist/node/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "bun": "./src/index.ts",
      "default": "./dist/node/index.js"
    },
    "./bin": {
      "bun": "./src/bin.ts",
      "default": "./dist/node/bin.js"
    }
  },
  "bin": {
    "dispatch-detector": "./dist/node/bin.js"
  },
  "files": ["src", "dist/node", "README.md"],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "build": "bun build src/index.ts src/bin.ts --target=node --format=esm --outdir dist/node --external @dispatch-ai/shared && bun build src/bin.ts --compile --outfile dist/dispatch-detector",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@dispatch-ai/shared": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
