{
  "name": "@dispatch-ai/cli",
  "version": "0.0.1",
  "description": "Pattern 3 autonomous coding CLI with a verifier you can trust.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dispatch-ai-labs/dispatch-ai.git"
  },
  "type": "module",
  "main": "./dist/node/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "bun": "./src/index.ts",
      "default": "./dist/node/index.js"
    },
    "./bin": {
      "bun": "./src/bin.ts",
      "default": "./dist/node/bin.js"
    }
  },
  "bin": {
    "dispatch": "./dist/node/bin.js"
  },
  "files": ["src", "dist/node", "README.md"],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "build": "bun build src/index.ts src/bin.ts --target=node --format=esm --outdir dist/node --external @dispatch-ai/shared --external @dispatch-ai/detector --external sql.js && bun build src/bin.ts --compile --outfile dist/dispatch",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@dispatch-ai/detector": "workspace:*",
    "@dispatch-ai/shared": "workspace:*",
    "sql.js": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/sql.js": "^1.4.9"
  },
  "publishConfig": {
    "access": "public"
  }
}
