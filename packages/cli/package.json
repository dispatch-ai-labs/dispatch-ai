{
  "name": "@dispatch-ai/cli",
  "version": "0.0.1",
  "description": "Pattern 3 autonomous coding CLI with a verifier you can trust.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "bin": {
    "dispatch": "./src/bin.ts"
  },
  "files": ["src", "README.md"],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "build": "bun build src/bin.ts --compile --outfile dist/dispatch"
  },
  "dependencies": {
    "@dispatch-ai/detector": "workspace:*",
    "@dispatch-ai/shared": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
