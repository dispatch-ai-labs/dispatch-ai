{
  "name": "@dispatch-ai/shared",
  "version": "0.0.1",
  "description": "Shared zod schemas and constants for dispatch-ai.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dispatch-ai-labs/dispatch-ai.git"
  },
  "type": "module",
  "main": "./dist/node/index.js",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "bun": "./src/index.ts",
      "default": "./dist/node/index.js"
    }
  },
  "files": ["src", "dist/node", "README.md"],
  "scripts": {
    "typecheck": "tsc -p tsconfig.json",
    "build": "bun build src/index.ts --target=node --format=esm --outdir dist/node --external zod",
    "prepack": "bun run build"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "publishConfig": {
    "access": "public"
  }
}
