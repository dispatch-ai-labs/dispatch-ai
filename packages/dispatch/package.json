{
  "name": "dispatch",
  "version": "0.0.1",
  "description": "Compatibility npx package for dispatch.ai CLI.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dispatch-ai-labs/dispatch-ai.git"
  },
  "type": "module",
  "bin": {
    "dispatch": "./dist/node/bin.js"
  },
  "files": ["dist/node", "README.md"],
  "scripts": {
    "typecheck": "echo 'compat package only'",
    "build": "bun build src/bin.ts --target=node --format=esm --outdir dist/node --external @dispatch-ai/cli",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@dispatch-ai/cli": "workspace:*"
  },
  "publishConfig": {
    "access": "public"
  }
}
