{
  "name": "dispatch-ai-monorepo",
  "private": true,
  "type": "module",
  "workspaces": ["packages/*"],
  "scripts": {
    "typecheck": "bun --filter '*' typecheck",
    "test": "bun test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "build": "bun --filter '*' build",
    "eval:snapshots": "bun --filter '@dispatch-ai/eval' eval:snapshots",
    "eval:live": "bun --filter '@dispatch-ai/eval' eval:live",
    "verify:release": "bun run scripts/verify-release.ts",
    "verify:external": "bun run scripts/check-external-readiness.ts",
    "demo:gif": "./scripts/generate-demo-gif.sh docs/assets/demo.gif"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/bun": "^1.1.13",
    "typescript": "^5.6.3"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
